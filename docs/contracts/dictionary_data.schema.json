{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sign-language-ai.local/contracts/dictionary_data.schema.json",
  "title": "Dictionary Data",
  "type": "object",
  "required": ["dictionary_info", "topics"],
  "properties": {
    "dictionary_info": {
      "type": "object",
      "required": ["version", "last_updated"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "last_updated": { "type": "string" }
      },
      "additionalProperties": true
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cloud_id", "name", "vocabularies"],
        "properties": {
          "cloud_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "vocabularies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["cloud_id", "word", "video_url"],
              "properties": {
                "cloud_id": { "type": "string", "minLength": 1 },
                "word": { "type": "string", "minLength": 1 },
                "video_url": { "type": "string", "minLength": 1 },
                "definition": { "type": "string" },
                "image_preview": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
